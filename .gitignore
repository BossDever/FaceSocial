# Model directories - exclude all model directories but keep their structure
ai-services/face-recognition/models/*/onnx/*
!ai-services/face-recognition/models/*/onnx/.gitkeep
ai-services/face-recognition/models/*/tensorrt/*
!ai-services/face-recognition/models/*/tensorrt/.gitkeep
ai-services/face-recognition/models/*/original/*
!ai-services/face-recognition/models/*/original/.gitkeep

# Similar pattern for other model directories
ai-services/face-detection/models/*
!ai-services/face-detection/models/.gitkeep
ai-services/liveness-detection/*/onnx/*
!ai-services/liveness-detection/*/onnx/.gitkeep
ai-services/liveness-detection/*/tensorrt/*
!ai-services/liveness-detection/*/tensorrt/.gitkeep
ai-services/liveness-detection/*/original/*
